<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:realsnag_media_downloader.ViewModels"
        x:Class="realsnag_media_downloader.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Realgar Media Downloader"
        Width="780"
        Height="740"
        MinWidth="520"
        MinHeight="500"
        Background="#18181B">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <!-- Form label -->
        <Style Selector="TextBlock.label">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="72" />
            <Setter Property="Foreground" Value="#B0B0B8" />
        </Style>
    </Window.Styles>

    <Window.Resources>
        <!-- Card background -->
        <SolidColorBrush x:Key="CardBg" Color="#222228" />
        <SolidColorBrush x:Key="CardBorder" Color="#2E2E36" />
        <!-- Button backgrounds -->
        <SolidColorBrush x:Key="PrimaryBg" Color="#2563EB" />
        <SolidColorBrush x:Key="SecondaryBg" Color="#3F3F46" />
        <SolidColorBrush x:Key="SecondaryBorder" Color="#52525B" />
        <SolidColorBrush x:Key="SubtleBg" Color="#27272A" />
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14" Margin="28,24" MaxWidth="720" HorizontalAlignment="Center">

            <!-- Header -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,6">
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Realgar Media Downloader" FontSize="20" FontWeight="SemiBold"
                               Foreground="#FAFAFA" />
                    <TextBlock Text="{Binding VersionString}" FontSize="10" Foreground="#52525B" />
                </StackPanel>
                <Button Grid.Column="1" VerticalAlignment="Center" Name="SettingsButton"
                        Background="{StaticResource SecondaryBg}" Foreground="#E4E4E7"
                        BorderBrush="{StaticResource SecondaryBorder}" BorderThickness="1"
                        CornerRadius="10" Padding="16,8" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                        <PathIcon Width="14" Height="14" VerticalAlignment="Center" Foreground="#A1A1AA"
                                  Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.22,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.22,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" />
                        <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- URL Card -->
            <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="22,18"
                    BorderThickness="1" BorderBrush="{StaticResource CardBorder}">
                <StackPanel Spacing="14">
                    <TextBox Name="UrlTextBox" Text="{Binding Url}"
                             Watermark="Paste a media link here..."
                             FontSize="14" CornerRadius="8" />

                    <!-- Thumbnail + metadata -->
                    <Grid ColumnDefinitions="Auto,*"
                          IsVisible="{Binding MetadataText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          Margin="0,2,0,0">
                        <Border CornerRadius="10" ClipToBounds="True" Width="170" Height="96"
                                Margin="0,0,16,0" Background="#16161A">
                            <Image Source="{Binding ThumbnailSource}" Stretch="UniformToFill" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding MetadataText}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" FontSize="13" LineHeight="22"
                                   Foreground="#D4D4D8" />
                    </Grid>

                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsFetchingMetadata}"
                                 Height="3" CornerRadius="2" />
                </StackPanel>
            </Border>

            <!-- Options Card -->
            <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="22,18"
                    BorderThickness="1" BorderBrush="{StaticResource CardBorder}">
                <StackPanel Spacing="16">

                    <!-- Format -->
                    <Grid ColumnDefinitions="72,*">
                        <TextBlock Text="Format" Classes="label" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="18">
                            <RadioButton Content="MP4" IsChecked="{Binding IsMp4}" GroupName="Format" />
                            <RadioButton Content="MP3" GroupName="Format" />
                        </StackPanel>
                    </Grid>

                    <!-- Quality -->
                    <Grid ColumnDefinitions="72,*">
                        <TextBlock Text="Quality" Classes="label" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Qualities}"
                                  SelectedItem="{Binding SelectedQuality}"
                                  HorizontalAlignment="Stretch" MinWidth="200" />
                    </Grid>

                    <!-- Save to -->
                    <Grid ColumnDefinitions="72,*,Auto">
                        <TextBlock Text="Save to" Classes="label" />
                        <Border Grid.Column="1" Background="{StaticResource SubtleBg}"
                                CornerRadius="8" Padding="12,7"
                                VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="{Binding OutputDirectory}"
                                       TextTrimming="CharacterEllipsis" FontSize="12"
                                       Foreground="#A1A1AA" />
                        </Border>
                        <Button Grid.Column="2" Name="BrowseButton"
                                Background="{StaticResource SecondaryBg}" Foreground="#E4E4E7"
                                BorderBrush="{StaticResource SecondaryBorder}" BorderThickness="1"
                                CornerRadius="8" Padding="14,6" Cursor="Hand">
                            <TextBlock Text="Browse" FontSize="12" VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <Separator Opacity="0.1" Margin="0,2" />

                    <!-- Trim -->
                    <CheckBox Content="Trim video" IsChecked="{Binding TrimEnabled}" />
                    <Grid ColumnDefinitions="*,Auto,*" IsVisible="{Binding TrimEnabled}" Margin="28,0,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Start" FontSize="11" Foreground="#71717A" />
                            <TextBox Text="{Binding TrimStart}" Watermark="00:00:00"
                                     MaxWidth="160" CornerRadius="8" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Center"
                                   Margin="14,14,14,0" Foreground="#52525B" FontSize="16" />
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="End" FontSize="11" Foreground="#71717A" />
                            <TextBox Text="{Binding TrimEnd}" Watermark="00:00:00"
                                     MaxWidth="160" CornerRadius="8" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Progress Card -->
            <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="22,14"
                    BorderThickness="1" BorderBrush="{StaticResource CardBorder}"
                    IsVisible="{Binding IsProgressVisible}">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="13"
                                   Foreground="#E4E4E7" />
                        <TextBlock Grid.Column="1" Foreground="#71717A" FontSize="12">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:0}%">
                                    <Binding Path="ProgressValue" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6" CornerRadius="3" />
                </StackPanel>
            </Border>

            <!-- Status (idle) -->
            <TextBlock Margin="4,0" FontSize="13" Foreground="#71717A"
                       IsVisible="{Binding !IsProgressVisible}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="Status: {0}">
                        <Binding Path="StatusText" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <!-- Logs -->
            <Expander Header="Logs" IsExpanded="False">
                <TextBox Text="{Binding LogText}" IsReadOnly="True" AcceptsReturn="True"
                         TextWrapping="Wrap" MaxHeight="220" MinHeight="80" FontSize="11"
                         FontFamily="Cascadia Code, Consolas, Menlo, monospace"
                         CornerRadius="8" />
            </Expander>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,8">
                <!-- Download -->
                <Button Command="{Binding DownloadCommand}" IsEnabled="{Binding !IsDownloading}"
                        Background="{StaticResource PrimaryBg}" Foreground="White"
                        CornerRadius="10" Padding="24,10" MinWidth="160"
                        HorizontalContentAlignment="Center" BorderThickness="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <PathIcon Width="14" Height="14" VerticalAlignment="Center"
                                  Foreground="White"
                                  Data="M12,2 L12,13.2 L16.6,8.6 L18,10 L11,17 L4,10 L5.4,8.6 L10,13.2 L10,2 Z M2,20 L20,20 L20,22 L2,22 Z" />
                        <TextBlock Text="Download" VerticalAlignment="Center"
                                   FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                </Button>
                <!-- Cancel -->
                <Button Command="{Binding CancelDownloadCommand}" IsEnabled="{Binding IsDownloading}"
                        Background="{StaticResource SecondaryBg}" Foreground="#E4E4E7"
                        BorderBrush="{StaticResource SecondaryBorder}" BorderThickness="1"
                        CornerRadius="10" Padding="18,9" MinWidth="100"
                        HorizontalContentAlignment="Center" Cursor="Hand">
                    <TextBlock Text="Cancel" VerticalAlignment="Center" FontSize="13" />
                </Button>
                <!-- Clear Logs -->
                <Button Command="{Binding ClearLogsCommand}"
                        Background="{StaticResource SecondaryBg}" Foreground="#E4E4E7"
                        BorderBrush="{StaticResource SecondaryBorder}" BorderThickness="1"
                        CornerRadius="10" Padding="18,9" MinWidth="110"
                        HorizontalContentAlignment="Center" Cursor="Hand">
                    <TextBlock Text="Clear Logs" VerticalAlignment="Center" FontSize="13" />
                </Button>
            </StackPanel>

            <!-- Footer -->
            <TextBlock Text="© 2026 Realgar. MIT License." FontSize="10" Foreground="#3F3F46"
                       HorizontalAlignment="Center" Margin="0,2,0,10" />

        </StackPanel>
    </ScrollViewer>

</Window>
