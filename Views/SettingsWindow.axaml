<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:realsnag_media_downloader.ViewModels"
        x:Class="realsnag_media_downloader.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Title="Settings"
        Width="420"
        Height="480"
        MinWidth="360"
        MinHeight="350"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="24,20">
        <StackPanel Spacing="20">

            <!-- Theme -->
            <StackPanel Spacing="8">
                <TextBlock Text="Theme" FontWeight="Bold" FontSize="15" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <RadioButton Content="Dark" IsChecked="{Binding IsDarkTheme}" />
                    <RadioButton Content="Light" IsChecked="{Binding !IsDarkTheme}" />
                </StackPanel>
            </StackPanel>

            <!-- Language -->
            <StackPanel Spacing="8">
                <TextBlock Text="Language" FontWeight="Bold" FontSize="15" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <RadioButton Content="English" IsChecked="{Binding IsEnglish}" />
                    <RadioButton Content="Deutsch" IsChecked="{Binding !IsEnglish}" />
                </StackPanel>
            </StackPanel>

            <Separator Opacity="0.2" />

            <!-- yt-dlp -->
            <StackPanel Spacing="8">
                <TextBlock Text="yt-dlp" FontWeight="Bold" FontSize="15" />
                <TextBlock Text="{Binding YtDlpVersionText}" FontSize="12" Opacity="0.7" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Update yt-dlp" Command="{Binding UpdateYtDlpCommand}"
                            IsEnabled="{Binding !IsUpdatingYtDlp}" />
                    <CheckBox Content="Auto-update" IsChecked="{Binding AutoUpdateYtDlp}"
                              VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- ffmpeg -->
            <StackPanel Spacing="4">
                <TextBlock Text="ffmpeg" FontWeight="Bold" FontSize="15" />
                <TextBlock Text="{Binding FfmpegStatusText}" FontSize="12" Opacity="0.7" />
            </StackPanel>

            <Separator Opacity="0.2" />

            <!-- About -->
            <StackPanel Spacing="4" Margin="0,0,0,16">
                <TextBlock Text="About" FontWeight="Bold" FontSize="15" />
                <TextBlock Text="(c) 2026 Realgar. MIT License." FontSize="12" Opacity="0.6" />
                <TextBlock Text="Built with Avalonia UI and yt-dlp." FontSize="12" Opacity="0.6" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,6" />
        </Style>
    </Window.Styles>

</Window>
